# Copy to .env and fill in the market you want to monitor.
POLYMARKET_MARKET_ID=replace-with-market-id
POLYMARKET_BASE_URL=https://api.polymarket.com/v0
VALUE_TEMPERATURE_DIFF_THRESHOLD=1.2
# Optional override for interpreting outcome names. Example format:
# OUTCOME_TEMPERATURE_MAP={"Over 24°C":24, "Under 24°C":23}
# The script will also fall back to parsing numbers from outcome labels.
